// UCR HPCC (hpcc.ucr.edu) site configuration.
// Combine with slurm or pixi_slurm profile:
//   -profile slurm,ucr_hpcc
//   -profile pixi_slurm,ucr_hpcc

process {
    withLabel: process_high_memory {
        queue = 'highmem'
    }
    withLabel: process_high {
        queue = 'epyc'
    }
    withLabel: process_medium {
        queue = 'intel'
    }
    withLabel: process_low {
        queue = 'intel'
    }
    withLabel: process_tree {
        queue = 'epyc'
    }

    // Fine-grained overrides for processes that sit across label boundaries
    withName: 'PHYLING_ALIGN'    { queue = 'highmem' }
    withName: 'PHYLING_FILTER'   { queue = 'epyc' }
    withName: 'PHYLING_TREE'     { queue = 'epyc' }
    withName: 'PHYKIT_CONCAT'    { queue = 'epyc' }
    withName: 'MODELTEST_NG'     { queue = 'epyc' }
    withName: 'IQTREE_MF'        { queue = 'epyc' }
    withName: 'IQTREE_BOOTSTRAP' { queue = 'epyc' }
    withName: 'RAXMLNG_PARSE'    { queue = 'epyc' }
    withName: 'RAXMLNG_ALL'      { queue = 'epyc' }
}
